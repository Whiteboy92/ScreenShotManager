<Window x:Class="ScreenShotManager.Views.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:components="clr-namespace:ScreenShotManager.Views.Components"
        Title="ScreenShotManager Settings" 
        Height="600" Width="700"
        MinHeight="600" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="False"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" 
                      ResizeBorderThickness="5" 
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Custom Title Bar -->
        <components:CustomTitleBar Grid.Row="0" Title="⚙️ Settings"/>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" 
                       Text="Screenshot Settings" 
                       Style="{StaticResource SectionHeaderStyle}"
                       FontSize="20"
                       Margin="0,10,0,20"/>

            <!-- Settings content -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Hidden"
                          PanningMode="VerticalOnly"
                          CanContentScroll="False"
                          PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                <StackPanel>
                    <!-- Save folder -->
                    <Border Background="{StaticResource CardBackgroundBrush}" 
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="📁 Save Location" 
                                       Style="{StaticResource SectionHeaderStyle}"
                                       FontSize="15"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Default save folder for screenshots:" 
                                       Style="{StaticResource LabelStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SaveFolderTextBox" 
                                         Grid.Column="0"
                                         IsReadOnly="True" 
                                         Style="{StaticResource ModernTextBoxStyle}"
                                         Margin="0,0,10,0"/>
                                <Button x:Name="BrowseFolderButton" 
                                        Grid.Column="1"
                                        Content="Browse..." 
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- File format -->
                    <Border Background="{StaticResource CardBackgroundBrush}" 
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="📸 File Format" 
                                       Style="{StaticResource SectionHeaderStyle}"
                                       FontSize="15"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Image format for saved screenshots:" 
                                       Style="{StaticResource LabelStyle}"/>
                            <components:CustomDropdown x:Name="FileFormatDropdown" 
                                                       SelectionChanged="FileFormatDropdown_SelectionChanged"/>
                        </StackPanel>
                    </Border>

                    <!-- Filename pattern -->
                    <Border Background="{StaticResource CardBackgroundBrush}" 
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="📝 Filename Pattern" 
                                       Style="{StaticResource SectionHeaderStyle}"
                                       FontSize="15"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Template for automatic filenames:" 
                                       Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="FilenamePatternTextBox" 
                                     Style="{StaticResource ModernTextBoxStyle}"/>
                            <TextBlock Text="Available tags: {date}, {time}" 
                                       FontSize="11" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,8,0,0"/>
                            <TextBlock x:Name="FilenamePreview" 
                                       FontSize="11" 
                                       Foreground="#4A9EFF"
                                       Margin="0,3,0,0"
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <!-- Display & Startup options -->
                    <Border Background="{StaticResource CardBackgroundBrush}" 
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="🎨 Preferences" 
                                       Style="{StaticResource SectionHeaderStyle}"
                                       FontSize="15"
                                       Margin="0,0,0,15"/>
                            
                            <CheckBox x:Name="DisableDimmingCheckBox" 
                                      Content="Disable screen dimming effect"
                                      Style="{StaticResource ModernCheckBoxStyle}"
                                      Margin="0,0,0,12"/>
                            
                            <CheckBox x:Name="StartOnLoginCheckBox" 
                                      Content="Start ScreenShotManager on Windows login"
                                      Style="{StaticResource ModernCheckBoxStyle}"/>
                            <TextBlock Text="(Requires administrator privileges)" 
                                       FontSize="11" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="32,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Auto-clean options -->
                    <Border Background="{StaticResource CardBackgroundBrush}" 
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="🧹 Auto-Clean" 
                                       Style="{StaticResource SectionHeaderStyle}"
                                       FontSize="15"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Maximum screenshots to keep (0 = unlimited):" 
                                       Style="{StaticResource LabelStyle}"/>
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="MaxHistorySlider" 
                                        Grid.Column="0"
                                        Minimum="0" 
                                        Maximum="1000" 
                                        TickFrequency="50"
                                        IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"
                                        Margin="0,0,15,0"/>
                                <Border Grid.Column="1"
                                        Background="{StaticResource AccentBrush}"
                                        CornerRadius="4"
                                        Padding="12,6"
                                        MinWidth="60">
                                    <TextBlock x:Name="MaxHistoryText" 
                                               Text="100" 
                                               Foreground="White"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

                </Grid>
            </Grid>
        </Window>

