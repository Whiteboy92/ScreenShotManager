<Window x:Class="ScreenShotManager.Views.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OverlayWindow" 
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Normal"
        ResizeMode="NoResize"
        Cursor="Cross">
            <Grid x:Name="RootGrid">
                <!-- Frozen screen background -->
                <Image x:Name="FrozenScreenImage" 
                       Stretch="Fill"
                       IsHitTestVisible="False"
                       RenderOptions.BitmapScalingMode="LowQuality"
                       RenderOptions.EdgeMode="Aliased"/>
        
        <!-- Canvas for selection and annotation -->
        <Canvas x:Name="MainCanvas" ClipToBounds="False" Background="Transparent">
            <!-- Dimming overlay outside selection (4 rectangles for performance) -->
            <Canvas x:Name="DimOverlayCanvas" IsHitTestVisible="False">
                <Rectangle x:Name="DimTop" Fill="#80000000" />
                <Rectangle x:Name="DimLeft" Fill="#80000000" />
                <Rectangle x:Name="DimRight" Fill="#80000000" />
                <Rectangle x:Name="DimBottom" Fill="#80000000" />
            </Canvas>
            
                    <!-- Screenshot preview (behind selection rectangle) -->
                    <Image x:Name="ScreenshotPreview" 
                           Visibility="Collapsed"
                           Stretch="Fill"
                           IsHitTestVisible="False"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           RenderOptions.EdgeMode="Unspecified"/>
            
            <!-- Selection rectangle (on top of preview) -->
            <Rectangle x:Name="SelectionRect"
                       Stroke="DeepSkyBlue"
                       StrokeThickness="3"
                       Fill="Transparent"
                       Visibility="Collapsed"
                       IsHitTestVisible="False"
                       Panel.ZIndex="10">
                <Rectangle.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                </Rectangle.Effect>
            </Rectangle>
            
            <!-- Annotation canvas -->
            <Canvas x:Name="AnnotationCanvas"
                    Visibility="Collapsed"
                    Background="Transparent"
                    IsHitTestVisible="False"/>
            
            <!-- Resize handles -->
            <Ellipse x:Name="HandleTopLeft" Width="12" Height="12" Fill="DeepSkyBlue" 
                     Stroke="White" StrokeThickness="2" Visibility="Collapsed" Cursor="SizeNWSE"/>
            <Ellipse x:Name="HandleTopRight" Width="12" Height="12" Fill="DeepSkyBlue" 
                     Stroke="White" StrokeThickness="2" Visibility="Collapsed" Cursor="SizeNESW"/>
            <Ellipse x:Name="HandleBottomLeft" Width="12" Height="12" Fill="DeepSkyBlue" 
                     Stroke="White" StrokeThickness="2" Visibility="Collapsed" Cursor="SizeNESW"/>
            <Ellipse x:Name="HandleBottomRight" Width="12" Height="12" Fill="DeepSkyBlue" 
                     Stroke="White" StrokeThickness="2" Visibility="Collapsed" Cursor="SizeNWSE"/>
            
            <!-- Annotation toolbar -->
            <Border x:Name="AnnotationToolbar"
                    Background="#F0F0F0"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- Brush toggle -->
                    <ToggleButton x:Name="BrushToggle" Width="36" Height="36" Margin="2"
                                  ToolTip="Draw (D)" Background="White" BorderBrush="Gray">
                        <TextBlock Text="🖌️" FontSize="18"/>
                    </ToggleButton>
                    
                    <Separator Width="1" Margin="4,0"/>
                    
                    <!-- Color picker -->
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <Button x:Name="ColorRed" Width="28" Height="28" Margin="1" 
                                Background="Red" BorderBrush="Gray" BorderThickness="1" ToolTip="Red"/>
                        <Button x:Name="ColorGreen" Width="28" Height="28" Margin="1" 
                                Background="LimeGreen" BorderBrush="Gray" BorderThickness="1" ToolTip="Green"/>
                        <Button x:Name="ColorBlue" Width="28" Height="28" Margin="1" 
                                Background="DodgerBlue" BorderBrush="Gray" BorderThickness="1" ToolTip="Blue"/>
                        <Button x:Name="ColorYellow" Width="28" Height="28" Margin="1" 
                                Background="Yellow" BorderBrush="Gray" BorderThickness="1" ToolTip="Yellow"/>
                        <Button x:Name="ColorBlack" Width="28" Height="28" Margin="1" 
                                Background="Black" BorderBrush="Gray" BorderThickness="1" ToolTip="Black"/>
                        <Button x:Name="ColorWhite" Width="28" Height="28" Margin="1" 
                                Background="White" BorderBrush="Black" BorderThickness="1" ToolTip="White"/>
                        <Button x:Name="ColorCustom" Width="28" Height="28" Margin="1" 
                                Background="White" BorderBrush="Gray" BorderThickness="2" 
                                ToolTip="Custom color...">
                            <TextBlock Text="🎨" FontSize="14"/>
                        </Button>
                    </StackPanel>
                    
                    <Separator Width="1" Margin="4,0"/>
                    
                    <!-- Brush size -->
                    <StackPanel Orientation="Horizontal" Margin="4,0" VerticalAlignment="Center">
                        <TextBlock Text="Size:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Button x:Name="BrushSizeDecrease" Content="-" Width="25" Height="25" 
                                FontWeight="Bold" Margin="0,0,2,0"/>
                        <Slider x:Name="BrushSizeSlider" Width="80" Minimum="1" Maximum="50" 
                                Value="3" VerticalAlignment="Center" TickFrequency="1"/>
                        <Button x:Name="BrushSizeIncrease" Content="+" Width="25" Height="25" 
                                FontWeight="Bold" Margin="2,0,4,0"/>
                        <TextBlock x:Name="BrushSizeText" Text="3" Width="25" 
                                   VerticalAlignment="Center" Margin="0,0,0,0"/>
                    </StackPanel>
                    
                    <Separator Width="1" Margin="4,0"/>
                    
                    <!-- Clear button -->
                    <Button x:Name="ClearButton" Width="36" Height="36" Margin="2"
                            ToolTip="Clear drawings" Background="White" BorderBrush="Gray">
                        <TextBlock Text="❌" FontSize="16"/>
                    </Button>
                    
                    <Separator Width="1" Margin="4,0"/>
                    
                    <!-- Save/Confirm button -->
                    <Button x:Name="ConfirmButton" Width="80" Height="36" Margin="2"
                            Content="Save ✅" Background="LimeGreen" Foreground="White"
                            FontWeight="Bold" BorderBrush="DarkGreen"/>
                </StackPanel>
            </Border>
        </Canvas>
        
        <!-- Instructions overlay -->
        <TextBlock x:Name="InstructionsText"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,20,0,0"
                   Foreground="White"
                   FontSize="16"
                   FontWeight="Bold"
                   Text="Drag to select an area • ESC to cancel • ENTER to capture">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.8"/>
            </TextBlock.Effect>
        </TextBlock>
    </Grid>
</Window>

