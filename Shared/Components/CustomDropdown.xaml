<UserControl x:Class="ScreenShotManager.Shared.Components.CustomDropdown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <UserControl.Resources>
        <Style x:Key="DropdownItemStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#404040"/>
                    <Setter Property="BorderBrush" Value="#4A9EFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <!-- Main dropdown button -->
        <Button x:Name="DropdownButton"
                Background="#2d2d2d"
                BorderBrush="#333333"
                BorderThickness="1"
                Padding="12,10"
                Cursor="Hand"
                Click="DropdownButton_Click"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Center">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <Button.Content>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="SelectedText" 
                           Grid.Column="0"
                           Text="PNG (Recommended)" 
                           Foreground="#D0D0D0"
                           FontSize="13"
                           VerticalAlignment="Center"/>
                
                <TextBlock Grid.Column="1" 
                           Text="▼" 
                           Foreground="#999999"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </Grid>
            </Button.Content>
        </Button>
        
        <!-- Dropdown popup -->
        <Popup x:Name="DropdownPopup"
               PlacementTarget="{Binding ElementName=DropdownButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="#2d2d2d"
                    BorderBrush="#333333"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,2,0,0"
                    MinWidth="{Binding ElementName=DropdownButton, Path=ActualWidth}">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                </Border.Effect>
                
                <StackPanel>
                    <!-- PNG Option -->
                    <Border x:Name="Item1" Style="{StaticResource DropdownItemStyle}"
                            MouseLeftButtonUp="Item_Click" Tag="PNG">
                        <StackPanel>
                            <TextBlock Text="PNG (Recommended)" 
                                       Foreground="#D0D0D0"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Lossless compression, best quality" 
                                       Foreground="#999999"
                                       FontSize="11"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- JPEG Option -->
                    <Border x:Name="Item2" Style="{StaticResource DropdownItemStyle}"
                            MouseLeftButtonUp="Item_Click" Tag="JPEG">
                        <StackPanel>
                            <TextBlock Text="JPEG" 
                                       Foreground="#D0D0D0"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Smaller file size, lossy compression" 
                                       Foreground="#999999"
                                       FontSize="11"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- BMP Option -->
                    <Border x:Name="Item3" Style="{StaticResource DropdownItemStyle}"
                            MouseLeftButtonUp="Item_Click" Tag="BMP">
                        <StackPanel>
                            <TextBlock Text="BMP" 
                                       Foreground="#D0D0D0"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Uncompressed, largest file size" 
                                       Foreground="#999999"
                                       FontSize="11"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>

